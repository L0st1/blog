  },
  "devDependencies": {
    "@shikijs/markdown-it": "^3.21.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.0.9",
    "cross-env": "^7.0.3",
    "markdown-it": "^14.1.0",
    "shiki": "^3.21.0",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.2"
  }
