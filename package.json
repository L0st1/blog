{
  "name": "nuxt3-full-ts-blog",
  "type": "module",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "nuxi dev",
    "typecheck:watch": "vue-tsc --noEmit --watch",
    "build": "nuxi build",
    "generate": "nuxi generate",
    "typecheck": "nuxi typecheck",
    "up": "taze major -I",
    "postinstall": "npx simple-git-hooks"
  },
  "dependencies": {
    "@inspira-ui/plugins": "^0.0.2",
    "@nuxt/content": "^3.11.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vueuse/core": "^14.2.1",
    "better-sqlite3": "^12.6.2",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.27",
    "motion-v": "^2.2.1",
    "nuxt": "^3.20.2",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/node": "^25.0.9",
    "@unocss/nuxt": "^66.6.8",
    "commitizen": "^4.3.1",
    "cross-env": "^7.0.3",
    "cz-git": "^1.12.0",
    "eslint": "^9.39.2",
    "lint-staged": "^15.5.2",
    "simple-git-hooks": "^2.13.1",
    "taze": "^19.9.2",
    "typescript": "^5.9.3",
    "unocss": "^66.6.8",
    "vue-tsc": "^3.2.2"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "commit-msg": "pnpm commitlint --edit"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  }
}
